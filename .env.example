# ─── Database (Supabase) ───
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ─── Redis (Upstash) ───
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# ─── Shopify ───
SHOPIFY_API_KEY=your_shopify_api_key_from_partners_dashboard
SHOPIFY_API_SECRET=your_shopify_api_secret_from_partners_dashboard
SCOPES=read_orders,write_orders,read_products,write_gift_cards,read_shipping
HOST=https://returnflow.co.uk

# ─── Encryption ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=32_byte_hex_string_64_chars_long

# ─── Email (Resend) ───
RESEND_API_KEY=re_your_resend_api_key

# ─── File storage (Cloudflare R2) ───
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=returnflow-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Managed carrier labels (Shippo aggregator — primary) ───
# ReturnFlow's own Shippo account powers "managed return labels" so merchants
# get labels with zero carrier setup. Leave unset to simulate. A shippo_test_
# token uses Shippo's free test mode; a live token buys real labels.
SHIPPO_API_KEY=
SHIPPO_SERVICELEVEL_TOKEN=
# Managed labels are billed to the merchant via a Shopify usage charge:
# postage + this flat service fee per label, up to the monthly cap they approve.
LABEL_FEE_GBP=0.50
LABEL_USAGE_CAP_GBP=200

# ─── Managed carrier labels (ShipEngine — alternative aggregator) ───
SHIPENGINE_API_KEY=
SHIPENGINE_CARRIER_ID=
SHIPENGINE_SERVICE_CODE=

# ─── Monitoring ───
SENTRY_DSN=https://your_sentry_dsn

# ─── BullMQ admin dashboard at /admin/queues ───
# Both required to enable; if either is missing the route returns 503.
QUEUE_DASHBOARD_USER=admin
QUEUE_DASHBOARD_PASS=change_me_to_a_strong_password

# ─── Runtime ───
PORT=3003
NODE_ENV=production
LOG_LEVEL=info

# ─── Portal URL (for CORS allowlist) ───
PORTAL_URL=https://returns.returnflow.co.uk
