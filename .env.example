# ─── Database (Supabase) ───
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ─── Redis (Upstash) ───
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# ─── Shopify ───
SHOPIFY_API_KEY=your_shopify_api_key_from_partners_dashboard
SHOPIFY_API_SECRET=your_shopify_api_secret_from_partners_dashboard
SCOPES=read_orders,write_orders,read_products,write_gift_cards,read_customers,read_shipping
HOST=https://returnflow.co.uk

# ─── Encryption ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=32_byte_hex_string_64_chars_long

# ─── Email (Resend) ───
RESEND_API_KEY=re_your_resend_api_key

# ─── File storage (Cloudflare R2) ───
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=returnflow-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Stripe (paid returns, Sprint 6+) ───
STRIPE_SECRET_KEY=sk_live_your_stripe_secret

# ─── Monitoring ───
SENTRY_DSN=https://your_sentry_dsn

# ─── Runtime ───
PORT=3003
NODE_ENV=production
LOG_LEVEL=info

# ─── Portal URL (for CORS allowlist) ───
PORTAL_URL=https://returns.returnflow.co.uk
